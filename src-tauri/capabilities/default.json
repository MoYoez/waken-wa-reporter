{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Shared capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "device-info:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
